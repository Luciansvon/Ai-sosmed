# =============================================
# Ai-sosmed — Environment Variables
# Copy ke .env lalu isi nilainya:  cp .env.example .env
# =============================================

# === WAJIB ===
# OpenRouter buat generate draf + gambar (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Token bot Discord (buat approval gate). https://discord.com/developers
DISCORD_TOKEN=your-discord-bot-token-here
# Discord user ID kamu (penerima DM approval auto-post). Aktifkan Developer Mode > klik kanan profil > Copy ID
BIMA_DISCORD_USER_ID=your-discord-user-id-here

# === THREADS API (wajib biar bisa publish) ===
# Generate access token di https://developers.facebook.com (Threads API)
THREADS_ACCESS_TOKEN=your-threads-access-token
THREADS_APP_ID=your-threads-app-id
THREADS_APP_SECRET=your-threads-app-secret
# Username Threads kamu (tanpa @). Dipakai buat bikin link permalink postingan +
# filter biar bot GAK bales komentarnya sendiri. Sangat disaranin diisi.
THREADS_USERNAME=

# === SCHEDULER ===
# true = auto-post jadwal acak harian (pagi/siang/malam) + scan komentar tiap 5 menit
ENABLE_THREADS_AUTO=true

# === OPSIONAL ===
# Model LLM buat draf Threads (default: Claude Sonnet — paling manusiawi)
THREADS_LLM_MODEL=anthropic/claude-sonnet-4.6
# Serper API buat ambil tren/konteks berita Indonesia (https://serper.dev). Kosong = skip tren.
SERPER_API_KEY=
# Channel Discord buat host gambar (fallback Catbox). Kosong = pakai DM owner sbg fallback.
THREADS_MEDIA_CHANNEL_ID=
# Model image gen OpenRouter (default: Gemini Flash Image / Nano Banana)
IMAGE_GEN_MODEL=google/gemini-3.1-flash-image-preview
# Vault Obsidian buat nyimpen analisa pola viral (opsional). Kosong = skip.
OBSIDIAN_PATH=
# agentmemory REST (viral learning). Default localhost; kosong/mati = no-op aman.
AGENTMEMORY_URL=http://127.0.0.1:3111
# Channel status startup (opsional). Kosong = cuma log.
BOT_STATUS_CHANNEL_ID=
